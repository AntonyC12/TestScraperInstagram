# ==================== .env.example ====================
# Archivo: Back/.env.example
# Descripción: Plantilla — copia a .env y completa los valores.
# NUNCA subas el .env real al repositorio.
# ========================================================

# ── Cuenta objetivo ──────────────────────────────────────
TARGET_ACCOUNT=username_de_la_cuenta_publica

# ── Cookies de identidad (copiar desde DevTools) ─────────
# DevTools → Application → Storage → Cookies → https://www.instagram.com
IG_SESSION_ID=tu_session_id_aqui
IG_MID=tu_mid_aqui
IG_DID=tu_ig_did_aqui
IG_NRCB=1
IG_CSRFTOKEN=tu_csrftoken_aqui
IG_DATR=tu_datr_aqui
IG_DS_USER_ID=tu_user_id_numerico

# ── App ID de Instagram Web (opcional, tiene fallback) ───
# Buscar en DevTools → Network → cualquier request a IG → Header: X-IG-App-ID
IG_APP_ID=936619743392459

# ── Límites de extracción ─────────────────────────────────
POSTS_LIMIT=20
COMMENTS_LIMIT=10

# ── Opciones de Playwright ────────────────────────────────
# true = headless (sin ventana), false = muestra el navegador
PLAYWRIGHT_HEADLESS=true

# ── Inteligencia Artificial (Análisis Visual/ OCEAN) ─────
# Obtén tu API Key en: https://aistudio.google.com/
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ── Credenciales opcionales (NO se usan en primera instancia) ─
IG_USERNAME=
IG_PASSWORD=